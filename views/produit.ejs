<%- include('partials/header') %>

<div class="container my-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <img src="/img/<%= produit.image %>"
                 alt="<%= produit.nom %>"
                 class="img-fluid rounded shadow-sm"
                 style="max-height:450px;width:100%;object-fit:contain;margin:auto;">
        </div>
        <div class="col-lg-6 ps-lg-5">
            <p class="text-uppercase text-muted small">Collection Exclusive</p>
            <h1 class="display-5 fw-bold mb-4 font-serif"><%= produit.nom %></h1>
            <h2 class="mb-4" style="color:#d4af37;"><%= Number(produit.prix).toLocaleString('fr-FR') %> FCFA</h2>
            <hr class="mb-3" style="border-color:#eee;">

            <!-- Badge stock -->
            <% if (produit.stock <= 0) { %>
                <span class="badge bg-danger mb-3 fs-6">Épuisé</span>
            <% } else if (produit.stock <= 5) { %>
                <span class="badge bg-warning text-dark mb-3 fs-6">Plus que <%= produit.stock %> en stock !</span>
            <% } else { %>
                <span class="badge bg-success mb-3 fs-6">En stock</span>
            <% } %>

            <p class="lead text-muted mb-5">
                <%= produit.description %><br><br>
                Une composition unique qui révèle votre personnalité. Un flacon raffiné pour un moment de pure olfaction.
            </p>

            <div class="d-grid gap-2 d-md-flex">
                <% if (produit.stock > 0) { %>
                <form action="/panier/ajouter/<%= produit.id %>" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-dark btn-lg rounded-0 px-5">Ajouter au panier</button>
                </form>
                <% } else { %>
                <button class="btn btn-secondary btn-lg rounded-0 px-5" disabled>Épuisé</button>
                <% } %>
                <a href="/" class="btn btn-outline-dark btn-lg rounded-0 px-4">Retour boutique</a>
            </div>
        </div>
    </div>

    <!-- Produits similaires -->
    <div class="mt-5 pt-5">
        <h3 class="text-center mb-4 font-serif">Vous aimerez aussi</h3>
        <div class="row">
            <% autres.forEach(function(p) { %>
            <div class="col-md-3 col-6">
                <div class="card mb-3 border-0">
                    <a href="/produit/<%= p.id %>">
                        <img src="/img/<%= p.image %>" class="card-img-top" loading="lazy"
                             style="height:200px;object-fit:cover;" alt="<%= p.nom %>">
                    </a>
                    <div class="card-body text-center"><small class="fw-bold"><%= p.nom %></small></div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
