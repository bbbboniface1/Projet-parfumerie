<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Sirani Parfumerie</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Design System Sirani -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
    <span>Livraison gratuite à Bamako dès 25 000 FCFA</span>
</div>

<!-- TOAST (flash session) -->
<% if (locals.toast) { %>
<div class="toast-container-sirani">
    <div id="sessionToast" class="toast toast-sirani align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-bold"><%= toast.msg %></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
<% } %>

<!-- NAVBAR -->
<nav class="navbar navbar-sirani navbar-expand-lg">
    <div class="container">

        <a class="navbar-brand-sirani" href="/">Sirani Parfumerie</a>

        <button class="navbar-toggler border-0 shadow-none" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link-sirani" href="/">Accueil</a></li>
                <li class="nav-item"><a class="nav-link-sirani" href="/">Collection</a></li>
                <li class="nav-item"><a class="nav-link-sirani" href="/atelier">Atelier</a></li>
                <li class="nav-item"><a class="nav-link-sirani" href="/contact">Contact</a></li>
                <li class="nav-item"><a class="nav-link-sirani" href="/mes-commandes">Mes commandes</a></li>
            </ul>

            <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                <!-- Recherche -->
                <form action="/" method="GET" class="d-flex align-items-center">
                    <input class="search-input"
                           type="search"
                           name="q"
                           placeholder="Rechercher..."
                           value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
                    <button class="search-btn" type="submit">
                        <i class="fa fa-search" style="font-size:0.8rem;"></i>
                    </button>
                </form>

                <!-- Panier -->
                <a href="/panier" class="cart-link">
                    <i class="fa fa-bag-shopping"></i>
                    <span>Panier</span>
                    <% if (cartCount > 0) { %>
                    <span class="cart-badge pulse"><%= cartCount %></span>
                    <% } %>
                </a>
            </div>
        </div>

    </div>
</nav>

<!-- Conteneur principal -->
<div class="container mt-4">
