<%- include('../partials/header') %>
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold font-serif">Commande #<%= commande.id %></h1>
        <a href="/admin" class="btn btn-outline-secondary rounded-0">← Retour admin</a>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Informations client</h5>
                <p><strong>Nom :</strong> <%= commande.nom %></p>
                <p><strong>Téléphone :</strong> <%= commande.telephone %></p>
                <p><strong>Adresse :</strong> <%= commande.adresse %>, <%= commande.codepostal %> <%= commande.ville %></p>
                <p><strong>Paiement :</strong> <%= commande.paiement %></p>
                <p><strong>Date :</strong> <%= new Date(commande.date_creation).toLocaleString('fr-FR') %></p>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">Articles commandés</h5>
                <table class="table table-bordered align-middle">
                    <thead class="table-dark">
                        <tr><th>Produit</th><th>Qté</th><th>Prix unit.</th><th>Sous-total</th></tr>
                    </thead>
                    <tbody>
                        <% commande.articlesList.forEach(item => { %>
                        <tr>
                            <td><%= item.nom %></td>
                            <td><%= item.qty %></td>
                            <td><%= Number(item.prix).toLocaleString('fr-FR') %> FCFA</td>
                            <td><%= Number(item.prix * item.qty).toLocaleString('fr-FR') %> FCFA</td>
                        </tr>
                        <% }); %>
                    </tbody>
                    <tfoot>
                        <tr class="table-light fw-bold">
                            <td colspan="3" class="text-end">Total :</td>
                            <td><%= Number(commande.total).toLocaleString('fr-FR') %> FCFA</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">Statut de la commande</h5>
                <% const badgeClass = commande.statut === 'Livrée' ? 'success' : commande.statut === 'Expédiée' ? 'warning' : 'secondary'; %>
                <p>Statut actuel : <span class="badge bg-<%= badgeClass %> fs-6"><%= commande.statut || 'En attente' %></span></p>
                <hr>
                <form action="/admin/commandes/<%= commande.id %>/statut" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Modifier le statut</label>
                        <select name="statut" class="form-select">
                            <option value="En attente"  <%= (commande.statut || 'En attente') === 'En attente'  ? 'selected' : '' %>>En attente</option>
                            <option value="Expédiée"    <%= commande.statut === 'Expédiée'    ? 'selected' : '' %>>Expédiée</option>
                            <option value="Livrée"      <%= commande.statut === 'Livrée'      ? 'selected' : '' %>>Livrée</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dark rounded-0 w-100">Enregistrer le statut</button>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
