<%- include('partials/header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold font-serif">Administration</h1>
        <div>
            <a href="/admin/ajouter-produit" class="btn btn-primary me-2">+ Ajouter un parfum</a>
            <a href="/logout" class="btn btn-outline-danger btn-sm">Se déconnecter</a>
        </div>
    </div>

    <!-- AJOUT ÉTAPE 4 : CARTES STATISTIQUES -->
    <style>
        .stat-card { background:#fff; border-left:4px solid #d4af37; border-radius:4px; box-shadow:0 2px 8px rgba(0,0,0,0.07); padding:20px 24px; }
        .stat-card-value { font-size:2rem; font-weight:700; color:#d4af37; line-height:1.1; }
        .stat-card-label { font-size:0.68rem; letter-spacing:2px; text-transform:uppercase; color:#888; margin-top:4px; margin-bottom:0; }
    </style>
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-value"><%= Number(stats.chiffreAffaires).toLocaleString('fr-FR') %></div>
                <p class="stat-card-label">Chiffre d'affaires (FCFA)</p>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-value"><%= stats.totalCommandes %></div>
                <p class="stat-card-label">Total commandes</p>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-value">
                    <%= stats.commandesEnAttente %>
                    <% if (stats.commandesEnAttente > 0) { %>
                        <span class="badge bg-warning text-dark ms-1" style="font-size:0.7rem;vertical-align:middle;">!</span>
                    <% } %>
                </div>
                <p class="stat-card-label">En attente</p>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-value"><%= stats.totalProduits %></div>
                <p class="stat-card-label">Produits en catalogue</p>
            </div>
        </div>
    </div>
    <!-- FIN CARTES STATISTIQUES -->

    <!-- ONGLETS -->
    <ul class="nav nav-tabs mb-4" id="adminTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link <%= activeTab === 'orders' ? 'active' : '' %>" data-bs-toggle="tab" data-bs-target="#orders" type="button">
                Commandes (<%= commandes.length %>)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link <%= activeTab === 'products' ? 'active' : '' %>" data-bs-toggle="tab" data-bs-target="#products" type="button">
                Catalogue (<%= produits.length %>)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link <%= activeTab === 'messages' ? 'active' : '' %>" data-bs-toggle="tab" data-bs-target="#messages" type="button">
                Messages (<%= messages.length %>)
            </button>
        </li>
    </ul>

    <style>
        #adminTab .nav-link { color:#000!important; border:none!important; }
        #adminTab .nav-link.active { color:#d4af37!important; border-bottom:3px solid #d4af37!important; font-weight:bold; }
        #adminTab .nav-link:hover { color:#d4af37!important; }
        .expand-row { cursor:pointer; }
        .msg-content { display:none; background:#f8f9fa; padding:10px; border-radius:4px; margin-top:5px; }
    </style>

    <div class="tab-content" id="adminTabContent">

        <!-- ONGLET COMMANDES -->
        <div class="tab-pane fade <%= activeTab === 'orders' ? 'show active' : '' %>" id="orders" role="tabpanel">
            <!-- AJOUT ÉTAPE 7 : bouton export CSV -->
            <div class="mb-3">
                <a href="/admin/export-commandes" class="btn btn-outline-success btn-sm rounded-0">
                    ⬇ Exporter en CSV (Excel)
                </a>
            </div>
            <% if (commandes && commandes.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-dark">
                        <tr><th>#</th><th>Client</th><th>Ville</th><th>Total</th><th>Statut</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% commandes.forEach(function(cmd) { %>
                        <% const badgeClass = cmd.statut === 'Livrée' ? 'success' : cmd.statut === 'Expédiée' ? 'warning' : 'secondary'; %>
                        <tr>
                            <td>#<%= cmd.id %></td>
                            <td><%= cmd.nom %><br><small class="text-muted"><%= cmd.telephone %></small></td>
                            <td><%= cmd.ville %></td>
                            <td><%= Number(cmd.total).toLocaleString('fr-FR') %> FCFA</td>
                            <td><span class="badge bg-<%= badgeClass %>"><%= cmd.statut || 'En attente' %></span></td>
                            <td class="d-flex gap-1">
                                <a href="/admin/commandes/<%= cmd.id %>" class="btn btn-sm btn-outline-primary">Gérer</a>
                                <button class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#modal<%= cmd.id %>">Détails</button>
                            </td>
                        </tr>
                        <!-- MODAL -->
                        <div class="modal fade" id="modal<%= cmd.id %>" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Commande #<%= cmd.id %></h5>
                                        <button class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <% if (cmd.email) { %><p><strong>Email :</strong> <%= cmd.email %></p><% } %>
                                        <p><strong>Adresse :</strong> <%= cmd.adresse %>, <%= cmd.codepostal %> <%= cmd.ville %></p>
                                        <p><strong>Paiement :</strong> <%= cmd.paiement %></p>
                                        <p><strong>Date :</strong> <%= new Date(cmd.date_creation).toLocaleString('fr-FR') %></p>
                                        <h6>Articles :</h6>
                                        <ul>
                                            <% cmd.articlesList.forEach(function(item) { %>
                                            <li><%= item.nom %> × <%= item.qty %> — <%= Number(item.prix * item.qty).toLocaleString('fr-FR') %> FCFA</li>
                                            <% }); %>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="alert alert-warning">Aucune commande.</div>
            <% } %>
        </div>

        <!-- ONGLET PRODUITS -->
        <div class="tab-pane fade <%= activeTab === 'products' ? 'show active' : '' %>" id="products" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-dark">
                        <tr><th>Image</th><th>Nom</th><th>Catégorie</th><th>Prix</th><th>Stock</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% produits.forEach(function(p) { %>
                        <tr>
                            <td><img src="/img/<%= p.image %>" loading="lazy" style="width:50px;height:50px;object-fit:cover;border-radius:4px;"></td>
                            <td><%= p.nom %></td>
                            <td><%= p.id_categorie == 1 ? 'Femme' : p.id_categorie == 2 ? 'Homme' : 'Unisex' %></td>
                            <td><%= Number(p.prix).toLocaleString('fr-FR') %> FCFA</td>
                            <td>
                                <% if(p.stock <= 0) { %><span class="badge bg-danger">Épuisé</span>
                                <% } else if(p.stock <= 5) { %><span class="badge bg-warning text-dark"><%= p.stock %></span>
                                <% } else { %><span class="badge bg-success"><%= p.stock %></span><% } %>
                            </td>
                            <td class="d-flex gap-1">
                                <a href="/admin/modifier-produit/<%= p.id %>" class="btn btn-sm btn-warning">Modifier</a>
                                <!-- Bouton ouvre modal confirmation suppression -->
                                <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#delModal<%= p.id %>">Supprimer</button>
                            </td>
                        </tr>
                        <!-- MODAL CONFIRMATION SUPPRESSION -->
                        <div class="modal fade" id="delModal<%= p.id %>" tabindex="-1">
                            <div class="modal-dialog modal-sm">
                                <div class="modal-content">
                                    <div class="modal-header bg-danger text-white">
                                        <h6 class="modal-title">Confirmer la suppression</h6>
                                        <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        Supprimer <strong><%= p.nom %></strong> définitivement ?
                                    </div>
                                    <div class="modal-footer">
                                        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                                        <form action="/admin/supprimer-produit/<%= p.id %>" method="POST" style="display:inline;">
                                            <button class="btn btn-danger btn-sm">Oui, supprimer</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ONGLET MESSAGES -->
        <div class="tab-pane fade <%= activeTab === 'messages' ? 'show active' : '' %>" id="messages" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-secondary">
                        <tr><th>Date</th><th>Client</th><th>Sujet</th><th>Message</th></tr>
                    </thead>
                    <tbody>
                        <% messages.forEach(function(msg) { %>
                        <tr>
                            <td class="text-nowrap"><%= new Date(msg.date_creation).toLocaleDateString('fr-FR') %></td>
                            <td><%= msg.nom %><br><small class="text-muted"><%= msg.email %></small></td>
                            <td><%= msg.sujet %></td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary expand-row"
                                        onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'block' ? 'none' : 'block'; this.textContent = this.textContent === '▼ Lire' ? '▲ Fermer' : '▼ Lire';">
                                    ▼ Lire
                                </button>
                                <div class="msg-content"><%= msg.contenu %></div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>
