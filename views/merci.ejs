<%- include('partials/header') %>

<div class="merci-wrapper">

    <!-- Check animé SVG -->
    <svg width="80" height="80" viewBox="0 0 80 80" style="margin-bottom:32px;">
        <circle cx="40" cy="40" r="36"
            style="fill:none;stroke:var(--color-gold);stroke-width:1.5;stroke-dasharray:226;stroke-dashoffset:226;animation:drawCheck 0.6s ease 0.1s forwards;"></circle>
        <path d="M24 40 L35 51 L56 29"
            style="fill:none;stroke:var(--color-gold);stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:50;stroke-dashoffset:50;animation:drawCheck 0.5s ease 0.7s forwards;"></path>
    </svg>

    <style>@keyframes drawCheck { to { stroke-dashoffset: 0; } }</style>

    <h1 class="merci-title">Merci pour votre commande !</h1>
    <p class="merci-text">
        Votre commande a été enregistrée avec succès chez <strong>Sirani Parfumerie</strong>.<br>
        Nous vous contacterons sous peu pour confirmer la livraison.
    </p>

    <% if (locals.lastOrder && lastOrder && lastOrder.articles) { %>
    <div style="max-width:420px;margin:0 auto 32px;text-align:left;
                border:1px solid rgba(0,0,0,0.08);padding:20px;">
        <p style="font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;
                  color:var(--color-text-muted);margin-bottom:12px;">
            Récapitulatif — Commande #<%= lastOrder.id %>
        </p>
        <% lastOrder.articles.forEach(function(item) { %>
        <div class="d-flex justify-content-between mb-1" style="font-size:0.88rem;">
            <span><%= item.nom %>
                <span style="color:var(--color-text-muted);">× <%= item.qty %></span>
            </span>
            <span><%= Number(item.prix * item.qty).toLocaleString('fr-FR') %> FCFA</span>
        </div>
        <% }); %>
        <hr style="margin:12px 0;border-color:rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between" style="font-weight:600;">
            <span>Total</span>
            <span><%= Number(lastOrder.total).toLocaleString('fr-FR') %> FCFA</span>
        </div>
        <p style="font-size:0.78rem;color:var(--color-text-muted);margin-top:8px;margin-bottom:0;">
            Paiement : <%= lastOrder.paiement %>
        </p>
    </div>
    <% } %>

    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center align-items-center">
        <a href="/" class="btn-merci">Explorer la collection</a>

        <% if (locals.lastEmail && lastEmail) { %>
        <a href="/mes-commandes?email=<%= encodeURIComponent(lastEmail) %>" class="btn-merci" style="border-color:var(--color-black);color:var(--color-black);">
            Voir mes commandes
        </a>
        <% } else { %>
        <a href="/mes-commandes" class="btn-merci" style="border-color:var(--color-black);color:var(--color-black);">
            Suivre une commande
        </a>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
