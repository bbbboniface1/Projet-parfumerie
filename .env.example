# Sirani Parfumerie — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS committer .env dans git

# Serveur
PORT=5000
NODE_ENV=development

# Base de données MySQL
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=db_parfumerie
DB_SOCKET=

# Session Express (chaîne aléatoire longue)
SESSION_SECRET=changez_moi_par_une_vraie_cle_secrete

# Admin — stocker le HASH bcrypt (généré avec scripts/generate-hash.js)
ADMIN_PASSWORD_HASH=$2b$10$REMPLACER_PAR_LE_VRAI_HASH

# Emails (Nodemailer — Gmail, Mailjet, Brevo, etc.)
# Laisser vide pour désactiver l'envoi d'emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_application

# Email admin pour recevoir les messages de contact
ADMIN_EMAIL=admin@sirani-parfumerie.com

# Niveau de logs (trace | debug | info | warn | error)
LOG_LEVEL=info

# URL publique de la boutique (pour les liens WhatsApp)
# En local : http://localhost:3000
# En production Replit : https://[nom-du-repl].replit.app
SHOP_URL=http://localhost:3000
